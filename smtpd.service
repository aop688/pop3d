[Unit]
Description=SMTP Server Daemon
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/sbin/smtpd
ExecReload=/bin/kill -HUP $MAINPID
KillMode=process
Restart=on-failure

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/mail /tmp

[Install]
WantedBy=multi-user.target
